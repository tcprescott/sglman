# Database — DB_HOST and DB_PORT are set automatically by docker-compose
DB_NAME=sglman
DB_USERNAME=sglman
DB_PASSWORD=changeme

# Discord bot
DISCORD_TOKEN=your-discord-bot-token-here

# Discord OAuth (required for web login — obtain from Discord Developer Portal)
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret
# Base URL of this app — used to auto-generate the OAuth redirect URI
# For local dev the default is http://localhost:8000 (no need to set it)
BASE_URL=https://yourdomain.com
# REDIRECT_URL and OAUTH_URL are derived automatically from BASE_URL and DISCORD_CLIENT_ID.
# Override only if you need a non-standard value.
# REDIRECT_URL=https://yourdomain.com/oauth/callback
# OAUTH_URL=https://discord.com/api/oauth2/authorize?client_id=...&redirect_uri=...&response_type=code&scope=identify

# NiceGUI session storage — REQUIRED. Signs the session that holds auth state.
# Generate a strong random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
STORAGE_SECRET=your-storage-secret-here

# App
ENVIRONMENT=production
# MOCK_DISCORD=true   # bypasses Discord OAuth and stubs DiscordService (local dev only;
#                       refused at startup when ENVIRONMENT=production)

# Error monitoring (optional) — set to your Sentry DSN to enable Sentry reporting.
# No-op when blank. Events are tagged with the ENVIRONMENT value above.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0   # >0 enables performance tracing (errors-only by default)

# Seed generation (optional)
# OOTR_API_KEY=your-ootr-api-key-here
# SMMAP_SPOILER_TOKEN=your-maprando-spoiler-token   # overrides the built-in default

# Challonge integration (optional) — register an app at https://connect.challonge.com
# and add both redirect URIs below to it. Without these the Challonge features stay off.
# CHALLONGE_CLIENT_ID=your-challonge-oauth-client-id
# CHALLONGE_CLIENT_SECRET=your-challonge-oauth-client-secret
# Redirect URIs are derived from BASE_URL when unset:
# CHALLONGE_SERVICE_REDIRECT_URI=https://yourdomain.com/challonge/oauth/callback
# CHALLONGE_PLAYER_REDIRECT_URI=https://yourdomain.com/challonge/link/callback
# CHALLONGE_SCOPES=me tournaments:read matches:read matches:write participants:read
# MOCK_CHALLONGE=true   # fakes the Challonge connection for local dev (refused in production)
# MOCK_CHALLONGE_IDENTITY=1   # which canned mock participant the next link binds to (1-4)
