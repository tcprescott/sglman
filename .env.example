# Database — DB_HOST and DB_PORT are set automatically by docker-compose
DB_NAME=sglman
DB_USERNAME=sglman
DB_PASSWORD=changeme

# Discord bot
DISCORD_TOKEN=your-discord-bot-token-here

# Discord OAuth (required for web login — obtain from Discord Developer Portal)
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret
# Base URL of this app — used to auto-generate the OAuth redirect URI
# For local dev the default is http://localhost:8000 (no need to set it)
BASE_URL=https://yourdomain.com
# REDIRECT_URL and OAUTH_URL are derived automatically from BASE_URL and DISCORD_CLIENT_ID.
# Override only if you need a non-standard value.
# REDIRECT_URL=https://yourdomain.com/oauth/callback
# OAUTH_URL=https://discord.com/api/oauth2/authorize?client_id=...&redirect_uri=...&response_type=code&scope=identify

# NiceGUI session storage — REQUIRED. Signs the session that holds auth state.
# Generate a strong random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
STORAGE_SECRET=your-storage-secret-here

# App
ENVIRONMENT=production
# Shared platform host (bare host[:port], no scheme) that serves the landing
# page, the /platform super-admin surface, and every tenant path-based at
# /t/<slug>. Defaults to the host component of BASE_URL when unset.
# PLATFORM_HOST=yourdomain.com
# MOCK_DISCORD=true   # bypasses Discord OAuth and stubs DiscordService (local dev only;
#                       refused at startup when ENVIRONMENT=production)

# Error monitoring (optional) — set to your Sentry DSN to enable Sentry reporting.
# No-op when blank. Events are tagged with the ENVIRONMENT value above.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0   # >0 enables performance tracing (errors-only by default)

# Device notifications (web push) — optional. Generate a keypair once with
# `poetry run python scripts/generate_vapid_keys.py`. The feature (and its
# settings UI) stays off while VAPID_PRIVATE_KEY is unset. Keep the private key
# secret and stable: rotating it invalidates every existing subscription.
# VAPID_PRIVATE_KEY=base64url-encoded-32-byte-private-key
# VAPID_SUBJECT=mailto:you@example.com   # contact sent to push services; defaults to BASE_URL when https

# Seed generation — each is required only for its randomizer; a missing value
# raises ValueError at generation time (not at startup).
# OOTR_API_KEY=your-ootr-api-key-here                # required for OoT Randomizer seeds
# SMMAP_SPOILER_TOKEN=your-maprando-spoiler-token    # required for Super Metroid Map Rando seeds
# MOCK_SEEDGEN=true   # returns fake seed permalinks instead of rolling real seeds
#                       (qualifier pool rolling + any generate_seed caller); local
#                       dev / browser-validation only, refused when ENVIRONMENT=production

# Challonge integration (optional) — register an app at https://connect.challonge.com
# and add both redirect URIs below to it. Without these the Challonge features stay off.
# CHALLONGE_CLIENT_ID=your-challonge-oauth-client-id
# CHALLONGE_CLIENT_SECRET=your-challonge-oauth-client-secret
# Redirect URIs are derived from BASE_URL when unset:
# CHALLONGE_SERVICE_REDIRECT_URI=https://yourdomain.com/challonge/oauth/callback
# CHALLONGE_PLAYER_REDIRECT_URI=https://yourdomain.com/challonge/link/callback
# CHALLONGE_SCOPES=me tournaments:read matches:read matches:write participants:read
# MOCK_CHALLONGE=true   # fakes the Challonge connection for local dev (refused in production)
# MOCK_CHALLONGE_IDENTITY=1   # which canned mock participant the next link binds to (1-4)

# Twitch account linking (optional) — register an app at https://dev.twitch.tv/console/apps
# and add the redirect URI below to it. Without these the Twitch link feature stays off.
# TWITCH_CLIENT_ID=your-twitch-oauth-client-id
# TWITCH_CLIENT_SECRET=your-twitch-oauth-client-secret
# Redirect URI is derived from BASE_URL when unset:
# TWITCH_REDIRECT_URI=https://yourdomain.com/twitch/oauth/callback
# MOCK_TWITCH=true   # fakes the Twitch link for local dev (refused in production)
# MOCK_TWITCH_IDENTITY=1   # which canned mock identity the next link binds to (1-4)

# racetime.gg account linking (optional) — register an OAuth app at
# https://racetime.gg/account/apps (read scope). These credentials are the
# identity-link OAuth app ONLY — the race-room bots use their own per-category
# client id/secret (RacetimeBot rows), not these. Without these the racetime link
# feature stays off.
# RACETIME_CLIENT_ID=your-racetime-oauth-client-id
# RACETIME_CLIENT_SECRET=your-racetime-oauth-client-secret
# Redirect URI is derived from BASE_URL when unset:
# RACETIME_REDIRECT_URI=https://yourdomain.com/racetime/oauth/callback
# MOCK_RACETIME=true   # fakes the racetime link for local dev (refused in production)
# MOCK_RACETIME_IDENTITY=1   # which canned mock identity the next link binds to (1-4)
