{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_architecture.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_async_safety.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_datetime_safety.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_migration_safety.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_nicegui_client_api.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_dry_regressions.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_safe_commands.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/install-deps.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/doc-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_syntax.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_file_length.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_no_orm_writes.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_audit_actions.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_audit_actor.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_slot_context.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_table_grid.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_markdown_xss.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_import_resolution.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_layer_exports.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_secret_leak.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_tenant_scoping.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_event_types.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/run_related_tests.py",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/doc-check.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_import_resolution.py",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_migration_drift.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_seed_coverage.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/run_full_tests.py",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
